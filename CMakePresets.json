{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name":  "v1",
      "displayName": "PicoADK v1 (RP2040)",
      "description": "Build for the RP2040 PicoADK",
      "binaryDir": "${sourceDir}/build/v1",
      "cacheVariables": {
        "PICOADK_BOARD":  "v1_rp2040",
        "PICO_PLATFORM":  "rp2040",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name":  "v1-debug",
      "inherits": "v1",
      "binaryDir": "${sourceDir}/build/v1-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name":  "v2",
      "displayName": "PicoADK v2 (RP2350)",
      "description": "Build for the RP2350 PicoADK",
      "binaryDir": "${sourceDir}/build/v2",
      "cacheVariables": {
        "PICOADK_BOARD":  "v2_rp2350",
        "PICO_PLATFORM":  "rp2350-arm-s",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name":  "v2-debug",
      "inherits": "v2",
      "binaryDir": "${sourceDir}/build/v2-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "v1",       "configurePreset": "v1" },
    { "name": "v1-debug", "configurePreset": "v1-debug" },
    { "name": "v2",       "configurePreset": "v2" },
    { "name": "v2-debug", "configurePreset": "v2-debug" }
  ]
}
